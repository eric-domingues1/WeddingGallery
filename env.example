# Cloudflare R2
R2_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY=sua_access_key
R2_SECRET_KEY=sua_secret_key
R2_BUCKET=nome-do-bucket
R2_PUBLIC_URL=https://seu-dominio-publico.r2.dev

# Senha de admin de CADA casal.
# O nome da variável aqui precisa ser IDÊNTICO ao valor de "senha_admin_env"
# daquele casal no casais.json.

# Ao adicionar um novo casal, adiciona uma nova linha aqui, por exemplo:
# ADMIN_SENHA_JOAO_MARIA=outra-senha-forte
